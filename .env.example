# SmartNode 环境变量示例
# 复制为 .env 并按需修改；.env 文件不应提交到版本库。
# 加载方式：将 .env 内容 export 到 shell，或使用 python-dotenv 在启动时自动加载。

# ── 运行环境 ───────────────────────────────────────────────────────────────
# development（默认）或 production
# 生产模式下 SMARTNODE_JWT_SECRET 与 SMARTNODE_API_KEY 为必填项，缺失则拒绝启动。
SMARTNODE_ENV=development

# ── 网络绑定 ───────────────────────────────────────────────────────────────
# 监听地址（默认 127.0.0.1；容器/公网部署改为 0.0.0.0）
SMARTNODE_HOST=127.0.0.1
# 监听端口（默认 5000）
SMARTNODE_PORT=5000

# ── 仿真参数 ───────────────────────────────────────────────────────────────
# 仿真时间倍率（正整数，默认 10）
# 1 = 实时；10 = 轨道平滑（推荐演示）；60 = 快速仿真；600 = 极速仿真
SMARTNODE_TIME_SCALE=10

# 随机种子（留空则非确定性；填入整数可复现仿真轨迹）
SMARTNODE_SEED=

# ── 日志 ──────────────────────────────────────────────────────────────────
# 日志级别：DEBUG / INFO（默认）/ WARNING / ERROR / CRITICAL
SMARTNODE_LOG_LEVEL=INFO
# 日志格式：console（默认，带颜色）/ json（适合容器/日志聚合）
LOG_FORMAT=console

# ── 鉴权与安全 ────────────────────────────────────────────────────────────
# JWT 签名密钥（生产环境必须替换为强随机值，勿使用此示例值）
SMARTNODE_JWT_SECRET=please-change-me-to-a-long-random-secret
# API Key 鉴权（留空则进入开放模式；生产环境建议填入）
SMARTNODE_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────
# 允许的跨域来源（逗号分隔；默认仅本机回环）
SMARTNODE_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ── 调试 ──────────────────────────────────────────────────────────────────
# 是否开启调试接口 /api/debug_status（0 关闭/默认；1 开启）
SMARTNODE_DEBUG_API=0
# 是否启动背景任务（0 关闭/默认；1 开启）
SMARTNODE_BACKGROUND_TASK_ENABLED=0
