# SmartNode 环境变量示例（复制为 .env 并按需修改；.env 不应入库）
SMARTNODE_ENV=development
SMARTNODE_JWT_SECRET=please-change-me-to-a-long-random-secret
SMARTNODE_API_KEY=
SMARTNODE_CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
SMARTNODE_HOST=127.0.0.1
SMARTNODE_PORT=5000
SMARTNODE_DEBUG_API=0
SMARTNODE_BACKGROUND_TASK_ENABLED=0
