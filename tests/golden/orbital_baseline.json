    "inclination_deg": 90.0,
    "raan_deg": 0.0,
    "arg_perigee_deg": 0.0,
    "mean_anomaly_deg": 0.0,
    "orbital_period_s": 5828.517,
    "orbital_period_tol": 1.0,
    "t0_lat_deg": 0.0,
    "t0_lon_deg": 0.0,
    "t0_alt_m": 621863.0,
    "t0_tol": 500.0
