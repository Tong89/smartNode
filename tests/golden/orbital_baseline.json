  "check_visibility": {
    "overhead_min_el_0": {
      "sat_lat": 35.0, "sat_lon": 139.0, "sat_alt_m": 500000,
      "gs_lat": 35.0, "gs_lon": 139.0,
      "min_elevation": 0,
      "expected": true,
      "note": "d < 0.001 边界，仰角 = 90°"
    },
    "overhead_min_el_90": {
      "sat_lat": 35.0, "sat_lon": 139.0, "sat_alt_m": 500000,
      "gs_lat": 35.0, "gs_lon": 139.0,
      "min_elevation": 90,
      "expected": true,
      "note": "正上方仰角 = 90°，满足任何 min_elevation 阈值"
    },
    "small_angle_below_threshold": {
      "sat_lat": 35.5, "sat_lon": 139.0, "sat_alt_m": 500000,
      "gs_lat": 35.0, "gs_lon": 139.0,
      "min_elevation": 10,
      "expected": true,
      "note": "地心角约 0.5°，精确 ENU 仰角约 83°（远高于 10° 阈值），ENU 拓扑坐标修正了原球面正弦近似的误差"
    },
    "moderate_angle_visible": {
      "sat_lat": 36.0, "sat_lon": 139.0, "sat_alt_m": 500000,
      "gs_lat": 35.0, "gs_lon": 139.0,
      "min_elevation": 10,
      "expected": true,
      "note": "地心角约 1°，仰角约 12.5°，高于 10° 阈值"
    },
    "large_angle_below_threshold": {
      "sat_lat": 95.0, "sat_lon": 139.0, "sat_alt_m": 500000,
      "gs_lat": 35.0, "gs_lon": 139.0,
      "min_elevation": 10,
      "expected": false,
      "note": "地心角约 60°，仰角约 3.7°，低于 10° 阈值"
    }
  },
  "check_geo_visibility": {
    "same_position": {
      "leo_lat": 0.0, "leo_lon": 0.0, "leo_alt_m": 500000,
      "geo_lat": 0.0, "geo_lon": 0.0, "geo_alt_m": 35786000,
      "expected": true,
      "note": "角度 = 0°，远小于 80° 阈值"
    },
    "angle_79_visible": {
      "leo_lat": 0.0, "leo_lon": 0.0, "leo_alt_m": 500000,
      "geo_lat": 0.0, "geo_lon": 79.0, "geo_alt_m": 35786000,
      "expected": true,
      "note": "角度 = 79°，恰好低于 80° 阈值"
    },
    "angle_81_not_visible": {
      "leo_lat": 0.0, "leo_lon": 0.0, "leo_alt_m": 500000,
      "geo_lat": 0.0, "geo_lon": 81.0, "geo_alt_m": 35786000,
      "expected": false,
      "note": "角度 = 81°，超过 80° 阈值"
    },
    "angle_90_not_visible": {
      "leo_lat": 0.0, "leo_lon": 0.0, "leo_alt_m": 500000,
      "geo_lat": 0.0, "geo_lon": 90.0, "geo_alt_m": 35786000,
      "expected": false,
      "note": "角度 = 90°，远超 80° 阈值"
    }
  }
