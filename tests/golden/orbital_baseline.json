{
  "_comment": "数值黄金基准 – 由 orbit.py 计算函数生成，用于 pytest.approx 回归断言。",
  "calc_central_angle": {
    "same_point": {
      "inputs": [0.0, 0.0, 0.0, 0.0],
      "expected": 0.0,
      "tol": 1e-9
    },
    "antipodal_equator": {
      "inputs": [0.0, 0.0, 0.0, 180.0],
      "expected": 180.0,
      "tol": 1e-6
    },
    "quarter_equator": {
      "inputs": [0.0, 0.0, 0.0, 90.0],
      "expected": 90.0,
      "tol": 1e-6
    },
    "north_to_south_pole": {
      "inputs": [90.0, 0.0, -90.0, 0.0],
      "expected": 180.0,
      "tol": 1e-6
    },
    "equator_45deg": {
      "inputs": [0.0, 0.0, 0.0, 45.0],
      "expected": 45.0,
      "tol": 1e-6
    },
    "diagonal_45_to_neg45": {
      "inputs": [45.0, 45.0, -45.0, -45.0],
      "expected": 120.0,
      "tol": 1e-4
    }
  },
  "orbital_elements_iss_like": {
